/* 全局样式 - 蓝色主题 */
page {
  --primary: #1677ff;
  --primary-light: #4096ff;
  --primary-bg: #e6f0ff;
  --success: #52c41a;
  --warning: #faad14;
  --danger: #ff4d4f;
  --bg: #f0f2f5;
  --card: #ffffff;
  --text: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border: #e8e8e8;
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background: var(--card);
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(22, 119, 255, 0.3);
}

.btn-danger {
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.3);
}

/* 金额显示 */
.amount {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary);
}

.amount.expense {
  color: #ff4d4f;
}

.amount.income {
  color: #52c41a;
}
