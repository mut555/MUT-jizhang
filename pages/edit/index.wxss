.container {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 80rpx;
  background: #f0f2f5;
}

.type-toggle {
  display: flex; background: #fff; border-radius: 12rpx; padding: 6rpx; margin-bottom: 20rpx;
}
.type-item {
  flex: 1; text-align: center; padding: 18rpx; font-size: 28rpx; color: #999; border-radius: 8rpx;
}
.type-item.active.expense { background: #ff4d4f; color: #fff; }
.type-item.active.income { background: #52c41a; color: #fff; }

.field-label { font-size: 26rpx; color: #666; margin-bottom: 16rpx; }
.amount-row { display: flex; align-items: center; }
.currency { font-size: 48rpx; font-weight: bold; color: #1677ff; margin-right: 12rpx; }
.amount-input { font-size: 56rpx; font-weight: bold; flex: 1; color: #333; }
.text-input { font-size: 32rpx; width: 100%; padding: 12rpx 0; border-bottom: 2rpx solid #e8e8e8; color: #333; }
.date-picker { font-size: 28rpx; color: #333; padding: 12rpx 0; border-bottom: 2rpx solid #e8e8e8; }

.category-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.cat-item {
  width: calc(25% - 9rpx); padding: 16rpx 0; text-align: center;
  background: #f8f8f8; border-radius: 8rpx; font-size: 26rpx; color: #666;
}
.cat-item.selected { background: #e6f0ff; color: #1677ff; font-weight: bold; }
.cat-name { display: block; margin-top: 4rpx; font-size: 22rpx; }

.actions { margin-top: 40rpx; }
.save-btn {
  width: 100%; padding: 28rpx; text-align: center;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff; font-size: 32rpx; font-weight: bold;
  border-radius: 12rpx;
  box-shadow: 0 6rpx 20rpx rgba(22,119,255,0.3);
  margin-bottom: 20rpx;
}
.delete-btn {
  width: 100%; padding: 28rpx; text-align: center;
  background: #fff; color: #ff4d4f; font-size: 28rpx;
  border-radius: 12rpx; border: 2rpx solid #ff4d4f;
}