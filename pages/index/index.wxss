.container { min-height: 100vh; padding: 20rpx; background: #f0f2f5; padding-bottom: 30rpx; }

/* 月度概览 */
.overview-card {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff; border-radius: 16rpx; padding: 36rpx 30rpx;
}
.month-label { font-size: 26rpx; opacity: 0.9; margin-bottom: 12rpx; }
.overview-amount { font-size: 56rpx; font-weight: bold; }

/* 筛选栏 */
.filter-bar {
  white-space: nowrap; padding: 16rpx 0; margin-bottom: 8rpx;
}
.filter-item {
  display: inline-block; padding: 12rpx 24rpx; margin-right: 12rpx;
  background: #fff; border-radius: 24rpx; font-size: 24rpx; color: #666;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.04);
}
.filter-item.active { background: #1677ff; color: #fff; }

/* 日期头 */
.date-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 8rpx 12rpx;
}
.date-text { font-size: 26rpx; font-weight: bold; color: #333; }
.date-total { font-size: 22rpx; color: #999; }

/* 账单卡片 */
.bill-card { padding: 20rpx 24rpx; margin-bottom: 8rpx; }
.bill-card:active { background: #f8f8f8; }
.bill-row { display: flex; align-items: center; }

.bill-icon-wrap {
  width: 72rpx; height: 72rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 32rpx; margin-right: 20rpx; flex-shrink: 0;
}
.bill-info { flex: 1; min-width: 0; }
.bill-item-name { font-size: 28rpx; color: #333; margin-bottom: 6rpx; }
.bill-meta { display: flex; align-items: center; gap: 8rpx; }
.bill-cat-tag { font-size: 20rpx; color: #1677ff; background: #e6f0ff; padding: 2rpx 10rpx; border-radius: 4rpx; }
.bill-source { font-size: 20rpx; }

.bill-right { text-align: right; flex-shrink: 0; }
.bill-amount { font-size: 30rpx; font-weight: bold; }
.bill-amount.expense { color: #ff4d4f; }
.bill-amount.income { color: #52c41a; }
.bill-time { font-size: 20rpx; color: #ccc; margin-top: 4rpx; }

/* 加载/空状态 */
.load-more { text-align: center; padding: 30rpx 0; font-size: 24rpx; color: #ccc; }
.empty-card { text-align: center; padding: 120rpx 30rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #666; margin-bottom: 8rpx; }
.empty-sub { font-size: 24rpx; color: #999; }

/* 语音悬浮按钮 */
.voice-float {
  position: fixed; right: 40rpx; bottom: 140rpx;
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  box-shadow: 0 8rpx 24rpx rgba(22,119,255,0.4);
  display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; z-index: 100;
}
.voice-float:active { transform: scale(0.9); }